-- Sen V4 Auto-Loader
local folderName       = "sen_v4"
local localPath       = folderName .. "/logo.png"
local blatantIconPath = folderName .. "/blatanticon.png"
local utilityIconPath = folderName .. "/utilityicon.png"
local infoIconPath    = folderName .. "/info.png"

-- Ensure directory structure exists
if makefolder then 
    pcall(function() 
        makefolder(folderName) 
    end) 
end

-- Asynchronous asset downloader
local function downloadAsset(path, url)
    if isfile and not isfile(path) then
        pcall(function()
            local success, content = pcall(function() return game:HttpGet(url) end)
            if success and content then
                writefile(path, content)
            end
        end)
    end
end

-- Fetch required design elements
downloadAsset(localPath, "https://raw.githubusercontent.com/stawischoppedshyt/sen/main/images/logo.png")
downloadAsset(blatantIconPath, "https://raw.githubusercontent.com/stawischoppedshyt/sen/main/images/blatanticon.png")
downloadAsset(utilityIconPath, "https://raw.githubusercontent.com/stawischoppedshyt/sen/main/images/utilityicon.png")
downloadAsset(infoIconPath, "https://raw.githubusercontent.com/stawischoppedshyt/sen/main/images/info.png")

-- Execute main framework script from repository
local success, err = pcall(function()
    loadstring(game:HttpGet("https://raw.githubusercontent.com/stawischoppedshyt/sen/main/loader/gui"))()
end)

if not success then
    warn("Sen V4 Loader Error: " .. tostring(err))
end
