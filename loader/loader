
local HttpService = game:GetService("HttpService")
local folderName  = "sen_v4"
local settingsFile = folderName .. "/config.json"


if makefolder then
    pcall(function()
        makefolder(folderName)
    end)
end


local assetUrls = {
    ["logo.png"]           = "https://raw.githubusercontent.com/stawischoppedshyt/sen/main/images/logo.png",
    ["blatanticon.png"]    = "https://raw.githubusercontent.com/stawischoppedshyt/sen/main/images/blatanticon.png",
    ["utilityicon.png"]    = "https://raw.githubusercontent.com/stawischoppedshyt/sen/main/images/utilityicon.png",
    ["info.png"]           = "https://raw.githubusercontent.com/stawischoppedshyt/sen/main/images/info.png",
    ["customsettings.png"] = "https://raw.githubusercontent.com/stawischoppedshyt/sen/main/images/customsettings.png",
    ["back.png"]           = "https://raw.githubusercontent.com/stawischoppedshyt/sen/main/images/back.png",
    ["close.png"]          = "https://raw.githubusercontent.com/stawischoppedshyt/sen/main/images/close.png"
}

-- Asset downloader
local function verifyAndDownloadAssets()
    for fileName, url in pairs(assetUrls) do
        local path = folderName .. "/" .. fileName
        if isfile and not isfile(path) then
            local success, content = pcall(function()
                return game:HttpGet(url)
            end)
            if success and content then
                pcall(function()
                    writefile(path, content)
                end)
            end
        end
    end
end

-- configurations if they do not exist
local function initializeConfig()
    if isfile and not isfile(settingsFile) then
        local defaultSettings = {
            theme = "Dark",
            menuKeybind = "RightBracket",
            speedEnabled = false,
            speedValue = 50,
            speedKeybind = "Unknown",
            flyEnabled = false,
            flyValue = 50,
            flyVerticalValue = 50,
            flyKeybind = "Unknown",
            flyKeysMode = "Space/LeftControl",
            flyMode = "Velocity",
            speedMode = "Velocity",
            holdJumpEnabled = false,
            holdJumpValue = 50,
            holdJumpKeybind = "Unknown",
            phaseEnabled = false,
            phaseKeybind = "Unknown",
            phaseMode = "Standard",
            spiderEnabled = false,
            spiderValue = 30,
            spiderKeybind = "Unknown",
            spiderAnimEnabled = true,
            antiFlingEnabled = false,
            antiFlingKeybind = "Unknown",
            notificationsEnabled = true,
            blurEnabled = true
        }
        pcall(function()
            writefile(settingsFile, HttpService:JSONEncode(defaultSettings))
        end)
    end
end

-- Execute loader
print("Sen V4: loading loader...")
verifyAndDownloadAssets()
initializeConfig()
print("Sen V4: Assets and environment = true.")

-- Execution of main GUI logic script payload
local function launchGuiPayload()
    local success, err = pcall(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/stawischoppedshyt/sen/refs/heads/main/loader/gui"))()
    end)
    if not success then
        warn("Sen V4 Loader Error: Failed to execute main script : " .. tostring(err))
    end
end

launchGuiPayload()
