    RunService.RenderStepped:Connect(function(dt)
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildWhichIsA("Humanoid")

        if char ~= lastPhaseCharacter then
            phaseCollisionState = nil
            lastPhaseCharacter = char
        end
        
        if root and hum then
            if not isSupportedGame then
                if senSettings.phaseEnabled then
                    setCharacterBasePartsCanCollide(char, false)
                    phaseCollisionState = false
                elseif phaseCollisionState ~= nil then
                    setCharacterBasePartsCanCollide(char, true)
                    phaseCollisionState = nil
                end
            else
                phaseCollisionState = nil
            end

            if senSettings.holdJumpEnabled and not senSettings.flyEnabled and UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                root.Velocity = Vector3.new(root.Velocity.X, senSettings.holdJumpValue, root.Velocity.Z)
            end

            if senSettings.speedEnabled and not senSettings.flyEnabled then
                local dir = hum.MoveDirection
                if senSettings.speedMode == "CFrame" then
                    root.CFrame = root.CFrame + Vector3.new(dir.X * senSettings.speedValue * dt, 0, dir.Z * senSettings.speedValue * dt)
                else
                    root.Velocity = Vector3.new(dir.X * senSettings.speedValue, root.Velocity.Y, dir.Z * senSettings.speedValue)
                end
            end

            if senSettings.flyEnabled then
                local dir = hum.MoveDirection
                local flyY = 0
                if senSettings.flyKeysMode == "Space/LeftControl" then
                    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then flyY = senSettings.flyVerticalValue end
                    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then flyY = -senSettings.flyVerticalValue end
                elseif senSettings.flyKeysMode == "Q/E" then
                    if UserInputService:IsKeyDown(Enum.KeyCode.E) then flyY = senSettings.flyVerticalValue end
                    if UserInputService:IsKeyDown(Enum.KeyCode.Q) then flyY = -senSettings.flyVerticalValue end
                elseif senSettings.flyKeysMode == "Z/C" then
                    if UserInputService:IsKeyDown(Enum.KeyCode.C) then flyY = senSettings.flyVerticalValue end
                    if UserInputService:IsKeyDown(Enum.KeyCode.Z) then flyY = -senSettings.flyVerticalValue end
                end

                root.Velocity = Vector3.new(dir.X * senSettings.flyValue, flyY, dir.Z * senSettings.flyValue)
            end

            if senSettings.spiderEnabled and not senSettings.flyEnabled then
                local dir = hum.MoveDirection
                if dir.Magnitude > 0 then
                    local params = RaycastParams.new()
                    params.FilterDescendantsInstances = {char}; params.FilterType = Enum.RaycastFilterType.Exclude
                    if workspace:Raycast(root.Position, root.CFrame.LookVector * 2.5, params) then
                        root.Velocity = Vector3.new(root.Velocity.X, senSettings.spiderValue, root.Velocity.Z)
                        if senSettings.spiderAnimEnabled then hum:ChangeState(Enum.HumanoidStateType.Climbing) end
                    end
                end
            end
        end
    end)

