                laserCleanupConnection = workspace.DescendantAdded:Connect(function(descendant)
                    if descendant.Name == "LaserHitbox" then
                        local plots = workspace:FindFirstChild("Plots")
                        if plots and descendant:IsDescendantOf(plots) then
                            descendant:Destroy()
                        end
                    end
                end)
            end
