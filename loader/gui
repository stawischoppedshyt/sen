        if senSettings.holdJumpKeybind ~= "Unknown" and input.KeyCode.Name == senSettings.holdJumpKeybind then triggerHoldJumpToggle() end
        if senSettings.flyKeybind ~= "Unknown" and input.KeyCode.Name == senSettings.flyKeybind then triggerFlyToggle() end
        if senSettings.phaseKeybind ~= "Unknown" and input.KeyCode.Name == senSettings.phaseKeybind then triggerPhaseToggle() end
        if senSettings.spiderKeybind ~= "Unknown" and input.KeyCode.Name == senSettings.spiderKeybind then triggerSpiderToggle() end
        if senSettings.antiFlingKeybind ~= "Unknown" and input.KeyCode.Name == senSettings.antiFlingKeybind then triggerAntiFlingToggle() end
        if triggerSemiInvisToggle and senSettings.semiInvisKeybind ~= "Unknown" and input.KeyCode.Name == senSettings.semiInvisKeybind then triggerSemiInvisToggle() end
        if triggerBestBrainrotTPToggle and senSettings.tpBestBrainrotKeybind ~= "Unknown" and input.KeyCode.Name == senSettings.tpBestBrainrotKeybind then triggerBestBrainrotTPToggle() end
    end

    UserInputService.InputBegan:Connect(function(input, processed)
        if not processed then
            handleKeybindTriggers(input)
        end
    end)

    menuBlur = Instance.new("BlurEffect")
    menuBlur.Name = "SenMenuBlur"
    menuBlur.Size = 24
    menuBlur.Enabled = senSettings.blurEnabled
    menuBlur.Parent = Lighting
    UserInputService.InputBegan:Connect(function(input)
        if senSettings.menuKeybind ~= "Unknown" and input.KeyCode.Name == senSettings.menuKeybind then
            menuOpen = not menuOpen
            mainFrame.Visible = menuOpen
            syncSubMenuVisibility()
            if menuBlur then menuBlur.Enabled = menuOpen and senSettings.blurEnabled end
        end
    end)

    if not uiCreated then
        createNotification("Finished Loading", "Press " .. senSettings.menuKeybind:upper() .. " to toggle menu UI")
    end
    uiCreated = true
    end
end

createMainUi()

Players.PlayerAdded:Connect(function(player)
    if player == LocalPlayer then
        task.defer(createMainUi)
    end
end)

if LocalPlayer then
    LocalPlayer.CharacterAdded:Connect(function()
        task.defer(createMainUi)
    end)
end
