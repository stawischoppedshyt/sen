        end

        local BestTarget = nil
        local CurrentTargetRarity = "none"

        local function FindBest()
            local plots = workspace:FindFirstChild("Plots")
            if not plots then return end

            local topPart, topScore = nil, -1
            local topRarity = "none"
            local activeParts = {}

            for _, plot in ipairs(plots:GetChildren()) do
                local sign = plot:FindFirstChild("PlotSign", true)
                local ownerLabel = sign and sign:FindFirstChild("TextLabel", true)
                local ownerText = ownerLabel and ownerLabel.Text or ""

                if ownerText:find(LocalPlayer.Name) or ownerText:find("Claim") or ownerText == "" then
                    for part, _ in pairs(trackedESPs) do
                        if part:IsDescendantOf(plot) then ClearESP(part) end
                    end
                    continue
                end

                for _, item in ipairs(plot:GetDescendants()) do
                    if item.Name == "AnimalOverhead" then
                        local gL = item:FindFirstChild("Generation", true)
                        local rL = item:FindFirstChild("Rarity", true)

                        if gL and rL then
                            local val = GetValue(gL.Text)
                            local rarityText = rL.Text:lower()

                            local isOg = rarityText:find("og")
                            local isSecret = rarityText:find("secret")

                            if isOg or isSecret then
                                local pScore = val
                                if isOg then pScore = val + 2000000000000000
                                elseif isSecret then pScore = val + 1000000000000000 end

                                if val >= getMinGenValue() then
                                    local body = item.Adornee or item.Parent
                                    if body and body:IsA("BasePart") then
                                        activeParts[body] = true
                                        CreateESP(body, (item:FindFirstChild("DisplayName", true) or {Text = "Animal"}).Text, gL.Text, isOg, isSecret)

                                        if pScore > topScore then
                                            topScore = pScore
                                            topPart = body
                                            topRarity = isOg and "og" or "secret"
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end

            for part, _ in pairs(trackedESPs) do
                if not activeParts[part] then
                    ClearESP(part)
                end
            end

            BestTarget = topPart
            CurrentTargetRarity = topRarity

            for part, billboard in pairs(trackedESPs) do
                if billboard and billboard.Parent then
                    local bg = billboard:FindFirstChild("BG")
                    local bestTag = bg and bg:FindFirstChild("BestTag")
                    if bestTag then
                        bestTag.Visible = (part == BestTarget)
                    end
                end
            end
        end

        task.spawn(function()
            while true do
                if renderESPEnabled then
                    FindBest()
                end
                task.wait(1.5)
            end
        end)

        local tickCounter = 0
        RunService.Heartbeat:Connect(function()
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")

            if BestTarget and (not BestTarget:IsDescendantOf(workspace) or not BestTarget.Parent) then
                BestTarget = nil
                Laser.Transparency = 1
                return
            end

            if hrp and BestTarget and renderESPEnabled then
                local startPos = hrp.Position
                local endPos = BestTarget.Position
                local distance = (startPos - endPos).Magnitude

                Laser.Size = Vector3.new(distance, 0.15, 0.15)
                Laser.CFrame = CFrame.lookAt(startPos, endPos) * CFrame.new(0, 0, -distance / 2) * CFrame.Angles(0, math.rad(90), 0)
                Laser.Transparency = 0

                if CurrentTargetRarity == "og" then
                    tickCounter = (tickCounter + 1) % 360
                    Laser.Color = Color3.fromHSV(tickCounter / 360, 1, 1)
                elseif CurrentTargetRarity == "secret" then
                    Laser.Color = Color3.fromRGB(255, 215, 0)
                else
                    Laser.Color = Color3.fromRGB(130, 50, 255)
                end
            else
                Laser.Transparency = 1
            end
        end)

