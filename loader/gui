        local function findBestBrainrotTarget(minValue)
            local plots = workspace:FindFirstChild("Plots")
            if not plots then
                return nil
            end

            local bestPart = nil
            local bestScore = -1

            for _, plot in ipairs(plots:GetChildren()) do
                local sign = plot:FindFirstChild("PlotSign", true)
                local ownerLabel = sign and sign:FindFirstChild("TextLabel", true)
                local ownerText = ownerLabel and ownerLabel.Text or ""

                if ownerText:find(LocalPlayer.Name) or ownerText:find("Claim") or ownerText == "" then
                    continue
                end

                for _, item in ipairs(plot:GetDescendants()) do
                    if item.Name == "AnimalOverhead" then
                        local generationLabel = item:FindFirstChild("Generation", true)
                        local rarityLabel = item:FindFirstChild("Rarity", true)
                        if generationLabel and rarityLabel then
                            local value = getGenerationValue(generationLabel.Text)
                            local rarity = rarityLabel.Text:lower()
                            local isOg = rarity:find("og")
                            local isSecret = rarity:find("secret")
                            if value >= minValue and (isOg or isSecret) then
                                local body = item.Adornee or item.Parent
                                if body and body:IsA("BasePart") then
                                    local score = value
                                    if isOg then
                                        score = score + 2000000000000000
                                    else
                                        score = score + 1000000000000000
                                    end
                                    if score > bestScore then
                                        bestScore = score
                                        bestPart = body
                                    end
                                end
                            end
                        end
                    end
                end
            end

            return bestPart
        end

        local function networkTeleportTo(cframeTarget)
            local character = LocalPlayer.Character
            local root = character and character:FindFirstChild("HumanoidRootPart")
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            if not root or not humanoid then
                return false
            end

            pcall(function()
                root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                humanoid:ChangeState(Enum.HumanoidStateType.Physics)
            end)

            task.wait(0.02)
            root.CFrame = cframeTarget

            pcall(function()
                root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            end)

            task.wait(0.02)
            pcall(function()
                humanoid:ChangeState(Enum.HumanoidStateType.Running)
            end)

            return true
        end

