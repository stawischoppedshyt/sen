local function setCharacterBasePartsCanCollide(character, state)
    if not character then
        return
    end

    for _, descendant in ipairs(character:GetDescendants()) do
        if descendant:IsA("BasePart") and descendant.CanCollide ~= state then
            descendant.CanCollide = state
        end
    end
end

local function disconnectAntiFlingConnections()
    for i = #antiFlingConnections, 1, -1 do
        local connection = antiFlingConnections[i]
        if connection then
            connection:Disconnect()
        end
        antiFlingConnections[i] = nil
    end
end

