                createNotification("Noclip Cam", "Incompatible exploit: missing setconstant/getconstants/getgc/getfenv")
                return false
            end

            local playerScripts = LocalPlayer:FindFirstChild("PlayerScripts")
            local playerModule = playerScripts and playerScripts:FindFirstChild("PlayerModule")
            local cameraModule = playerModule and playerModule:FindFirstChild("CameraModule")
            local zoomController = cameraModule and cameraModule:FindFirstChild("ZoomController")
            local popper = zoomController and zoomController:FindFirstChild("Popper")
            if not popper then
                createNotification("Noclip Cam", "CameraModule.ZoomController.Popper not found")
                return false
            end

            local patched = false
            for _, fn in ipairs(getgc()) do
                if type(fn) == "function" then
                    local ok, env = pcall(getfenv, fn)
                    if ok and env and env.script == popper then
                        local ok2, consts = pcall(gc, fn)
                        if ok2 and type(consts) == "table" then
                            for index, value in ipairs(consts) do
                                local num = tonumber(value)
                                if num == 0.25 then
                                    pcall(function() sc(fn, index, 0) end)
                                    patched = true
                                elseif num == 0 then
                                    pcall(function() sc(fn, index, 0.25) end)
                                    patched = true
                                end
                            end
                        end
                    end
                end
            end

            if patched then
                cameraNoclipEnabled = enabled
                senSettings.cameraNoclipEnabled = enabled
                saveCurrentSettings()
                titleLabel.TextColor3 = enabled and accentColor or themeConfigs[senSettings.theme].textMain
                createNotification("Noclip Cam", enabled and "Enabled" or "Disabled")
                return true
            else
                createNotification("Noclip Cam", "No matching camera constants found")
                return false
            end
        end

