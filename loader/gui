    -- Dynamic Movement Loops using Root Velocity Configuration
    RunService.RenderStepped:Connect(function()
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildWhichIsA("Humanoid")
        
        if root and hum then
            -- 1. Handling basic speed modification loop
            if senSettings.speedEnabled and not senSettings.flyEnabled then
                local dir = hum.MoveDirection
                root.Velocity = Vector3.new(dir.X * senSettings.speedValue, root.Velocity.Y, dir.Z * senSettings.speedValue)
            end

            -- 2. Root velocity fly implementation tracking distinct horizontal/vertical bounds
            if senSettings.flyEnabled then
                local dir = hum.MoveDirection
                local flyY = 0

                if senSettings.flyKeysMode == "Space/LeftControl" then
                    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then flyY = senSettings.flyVerticalValue end
                    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then flyY = -senSettings.flyVerticalValue end
                elseif senSettings.flyKeysMode == "Q/E" then
                    if UserInputService:IsKeyDown(Enum.KeyCode.E) then flyY = senSettings.flyVerticalValue end
                    if UserInputService:IsKeyDown(Enum.KeyCode.Q) then flyY = -senSettings.flyVerticalValue end
                elseif senSettings.flyKeysMode == "Z/C" then
                    if UserInputService:IsKeyDown(Enum.KeyCode.C) then flyY = senSettings.flyVerticalValue end
                    if UserInputService:IsKeyDown(Enum.KeyCode.Z) then flyY = -senSettings.flyVerticalValue end
                end

                root.Velocity = Vector3.new(dir.X * senSettings.flyValue, flyY, dir.Z * senSettings.flyValue)
            end
        end
    end)

