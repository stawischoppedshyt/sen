    local function setupBindLogic(settingsKey, bindBox)
        local listening = false
        bindBox.MouseButton1Click:Connect(function() listening = true; bindBox.Text = "..." end)
        UserInputService.InputBegan:Connect(function(input)
            if listening and input.UserInputType == Enum.UserInputType.Keyboard then
                listening = false
                if input.KeyCode == Enum.KeyCode.Escape then
                    senSettings[settingsKey] = "Unknown"
                else
                    senSettings[settingsKey] = input.KeyCode.Name
                end
                local displayName = senSettings[settingsKey] == "Unknown" and "-" or senSettings[settingsKey]:upper()
                if #displayName > 3 then displayName = displayName:sub(1, 3) end
                bindBox.Text = displayName
                saveCurrentSettings()
            end
        end)
    end

