        local function getCharacterHumanoidRoot()
            local character = LocalPlayer.Character
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            local root = character and character:FindFirstChild("HumanoidRootPart")
            if not character or not humanoid or not root then
                return nil, nil, nil
            end
            return character, humanoid, root
        end

        local function playFreezeAnim(humanoid)
            if not humanoid then
                return
            end
            if semiInvisTrack then
                semiInvisTrack:Stop()
                semiInvisTrack = nil
            end
            local anim = Instance.new("Animation")
            anim.AnimationId = ANIMATION_ID
            semiInvisTrack = humanoid:LoadAnimation(anim)
            semiInvisTrack.Priority = Enum.AnimationPriority.Action4
            semiInvisTrack:Play()
            task.delay(0.1, function()
                if semiInvisTrack and semiInvisTrack.IsPlaying then
                    semiInvisTrack.TimePosition = FREEZE_TIMEPOS
                    semiInvisTrack:AdjustSpeed(0)
                end
            end)
        end

        local function unfreezeAnim(humanoid)
            if humanoid then
                for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
                    track:AdjustSpeed(1)
                end
            end
            if semiInvisTrack then
                semiInvisTrack:Stop()
                semiInvisTrack = nil
            end
        end

        local function clearSemiInvisRig()
            if semiInvisAlign then
                semiInvisAlign:Destroy()
                semiInvisAlign = nil
            end
            if semiInvisAttachment then
                semiInvisAttachment:Destroy()
                semiInvisAttachment = nil
            end
        end

        local function applySemiInvisStart()
            local _, humanoid, root = getCharacterHumanoidRoot()
            if not humanoid or not root then
                return false
            end

            playFreezeAnim(humanoid)
            humanoid:ChangeState(Enum.HumanoidStateType.Physics)
            humanoid.AutoRotate = false
            root.CustomPhysicalProperties = noBouncePhys

            clearSemiInvisRig()
            semiInvisAttachment = Instance.new("Attachment")
            semiInvisAttachment.Parent = root

            semiInvisAlign = Instance.new("AlignOrientation")
            semiInvisAlign.Mode = Enum.OrientationAlignmentMode.OneAttachment
            semiInvisAlign.Responsiveness = 100
            semiInvisAlign.Attachment0 = semiInvisAttachment
            semiInvisAlign.Parent = root

            local _, yaw, _ = root.CFrame:ToEulerAnglesYXZ()
            semiInvisTargetYaw = yaw
            return true
        end

        local function applySemiInvisStop()
            local _, humanoid, root = getCharacterHumanoidRoot()

            if humanoid then
                unfreezeAnim(humanoid)
                humanoid.AutoRotate = true
                humanoid.HipHeight = 2
            end
            if root then
                root.CustomPhysicalProperties = defaultPhys
                root.CFrame = root.CFrame + Vector3.new(0, 3, 0)
                root.AssemblyLinearVelocity = Vector3.zero
            end

            task.delay(0.1, function()
                local _, delayedHumanoid = getCharacterHumanoidRoot()
                if delayedHumanoid then
                    delayedHumanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end)

            clearSemiInvisRig()
        end

        local function ensureSemiInvisLoop()
            if semiInvisSteppedConnection then
                return
            end
            semiInvisSteppedConnection = RunService.Stepped:Connect(function()
                if not semiInvisEnabled then
                    return
                end

                local character, humanoid, root = getCharacterHumanoidRoot()
                if not character or not humanoid or not root then
                    return
                end

                if not semiInvisAlign or not semiInvisAttachment or semiInvisAttachment.Parent ~= root then
                    applySemiInvisStart()
                end

                humanoid.HipHeight = DEPTH

                if root.AssemblyLinearVelocity.Y > 0 then
                    root.AssemblyLinearVelocity = Vector3.new(root.AssemblyLinearVelocity.X, 0, root.AssemblyLinearVelocity.Z)
                end

                local moveDirection = humanoid.MoveDirection
                local speed = humanoid.WalkSpeed

                if moveDirection.Magnitude > 0 then
                    local desiredVelocity = moveDirection.Unit * speed
                    root.AssemblyLinearVelocity = Vector3.new(desiredVelocity.X, root.AssemblyLinearVelocity.Y, desiredVelocity.Z)
                    semiInvisTargetYaw = math.atan2(-moveDirection.X, -moveDirection.Z)
                else
                    root.AssemblyLinearVelocity = Vector3.new(0, root.AssemblyLinearVelocity.Y, 0)
                end

                if UserInputService:IsKeyDown(Enum.KeyCode.Space) and not semiInvisJumpCooldown then
                    semiInvisJumpCooldown = true
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                    task.delay(0.35, function()
                        semiInvisJumpCooldown = false
                    end)
                end

                if semiInvisAlign then
                    semiInvisAlign.CFrame = CFrame.fromEulerAnglesYXZ(math.rad(PITCH), semiInvisTargetYaw, math.rad(ROLL))
                end

                for _, child in ipairs(character:GetChildren()) do
                    if child:IsA("BasePart") and child.Name ~= "HumanoidRootPart" then
                        child.CanCollide = false
                    end
                end

                if humanoid:GetState() ~= Enum.HumanoidStateType.Physics then
                    humanoid:ChangeState(Enum.HumanoidStateType.Physics)
                end
            end)
        end

        local function setSemiInvisEnabled(enabled)
            if enabled and not applySemiInvisStart() then
                createNotification("Semi Invis", "Character is not ready yet")
                return false
            end

            semiInvisEnabled = enabled
            senSettings.semiInvisEnabled = enabled
            saveCurrentSettings()
            titleLabel.TextColor3 = enabled and accentColor or themeConfigs[senSettings.theme].textMain

            if enabled then
                ensureSemiInvisLoop()
            else
                if semiInvisSteppedConnection then
                    semiInvisSteppedConnection:Disconnect()
                    semiInvisSteppedConnection = nil
                end
                applySemiInvisStop()
            end
            return true
        end

        local function toggleSemiInvisState()
            local desiredState = not semiInvisEnabled
